<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="VoiceCraft.Client.Views.Home.CrashLogView"
             x:Name="Root"
             xmlns:locale="clr-namespace:VoiceCraft.Client.Locales"
             xmlns:vm="clr-namespace:VoiceCraft.Client.ViewModels.Home"
             x:DataType="vm:CrashLogViewModel">
    <Panel>
        <ListBox Background="Transparent"
                 ItemsSource="{Binding CrashLogs}">
            <ListBox.Styles>
                <Style Selector="ListBoxItem">
                    <Setter Property="CornerRadius" Value="5" />
                    <Setter Property="Margin" Value="0,0,0,5" />
                </Style>
            </ListBox.Styles>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid RowDefinitions="Auto, Auto, Auto"
                          ColumnDefinitions="*, Auto">
                        <TextBlock Grid.ColumnSpan="2"
                                   HorizontalAlignment="Left"
                                   VerticalAlignment="Center"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   Text="{Binding Key}"
                                   Margin="0,0,0,10" />

                        <TextBlock Grid.Row="1"
                                   Grid.ColumnSpan="2"
                                   HorizontalAlignment="Left"
                                   VerticalAlignment="Center"
                                   FontSize="13"
                                   Text="{Binding Value.Message}"
                                   MaxLines="8" />
                        <!-- Only show a small amount of text, to not annihilate mobile rendering. -->

                        <TextBlock Grid.Row="2"
                                   VerticalAlignment="Center"
                                   Margin="0,10,0,0"
                                   Text="{Binding Value.DumpUrl}"
                                   IsVisible="{Binding Value.HasDumpUrl}" />

                        <Button Grid.Row="2"
                                Grid.Column="1"
                                MinWidth="132"
                                Height="40"
                                Margin="10,10,0,0"
                                Padding="12,0"
                                CornerRadius="20"
                                Command="{Binding DataContext.CopyDumpLinkCommand, ElementName=Root}"
                                CommandParameter="{Binding}">
                            <TextBlock VerticalAlignment="Center"
                                       Text="{locale:Localize CrashLogs.Action.DumpLink}" />
                        </Button>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
        <StackPanel HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    Margin="15"
                    Spacing="10">
            <Button Width="50"
                    Height="50"
                    CornerRadius="50"
                    Command="{Binding CopyLogsCommand}">
                <PathIcon Data="{StaticResource CopyRegular}" />
            </Button>
            <Button Width="50"
                    Height="50"
                    CornerRadius="50"
                    Command="{Binding ClearLogsCommand}">
                <PathIcon Data="{StaticResource DeleteRegular}" />
            </Button>
        </StackPanel>
    </Panel>
</UserControl>

