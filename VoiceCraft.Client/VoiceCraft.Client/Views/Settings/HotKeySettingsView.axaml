<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:VoiceCraft.Client.ViewModels.Data"
             xmlns:settings="clr-namespace:VoiceCraft.Client.ViewModels.Settings"
             xmlns:locale="using:VoiceCraft.Client.Locales"
             mc:Ignorable="d"
             d:DesignWidth="800"
             d:DesignHeight="450"
             x:Name="Root"
             x:DataType="settings:HotKeySettingsViewModel"
             x:Class="VoiceCraft.Client.Views.Settings.HotKeySettingsView">
    <Grid RowDefinitions="Auto, *">
            <Grid Grid.Row="0"
                  Margin="0,0,0,10"
                  Background="{DynamicResource BackgroundBrush}">
                <TextBlock Margin="10"
                           VerticalAlignment="Center"
                           FontSize="20"
                           FontWeight="Bold"
                           Text="{locale:Localize Settings.HotKey.Title}"
                           TextAlignment="Center" />
                <Button Padding="10"
                        VerticalAlignment="Stretch"
                        Background="Transparent"
                        Command="{Binding CancelCommand}"
                        CornerRadius="0">
                    <PathIcon Data="{DynamicResource ArrowLeftRegular}" />
                </Button>
            </Grid>
            <ScrollViewer Grid.Row="1"
                          Margin="10,0,10,10">
                <Border VerticalAlignment="Top"
                        Padding="15"
                        Classes="card">
                    <StackPanel Spacing="14">
                        <Border Classes="card"
                                Padding="12">
                            <Grid ColumnDefinitions="*,Auto"
                                  ColumnSpacing="12">
                                <StackPanel Grid.Column="0"
                                            Spacing="4">
                                    <TextBlock FontSize="16"
                                               FontWeight="Bold"
                                               Text="{locale:Localize Settings.HotKey.PlayPushToTalkCues}" />
                                </StackPanel>
                                <ToggleSwitch Grid.Column="1"
                                              OffContent=""
                                              OnContent=""
                                              IsChecked="{Binding PlayPushToTalkCues}" />
                            </Grid>
                        </Border>
                        <ItemsControl ItemsSource="{Binding HotKeys}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:HotKeyActionDataViewModel">
                                    <Border Classes="card"
                                            Padding="12"
                                            Margin="0,0,0,8">
                                        <Grid RowDefinitions="Auto,Auto"
                                              ColumnDefinitions="*,Auto"
                                              ColumnSpacing="12"
                                              RowSpacing="8">
                                            <TextBlock FontSize="16"
                                                       FontWeight="Bold"
                                                       Grid.Row="0"
                                                       Grid.Column="0"
                                                       Text="{locale:Localize {Binding Title}}" />
                                            <Border Grid.Row="1"
                                                    Grid.Column="0"
                                                    Classes="tag"
                                                    Padding="6,4"
                                                    HorizontalAlignment="Left">
                                                <TextBlock Text="{Binding Keybind}" />
                                            </Border>
                                            <Button Grid.RowSpan="2"
                                                    Grid.Column="1"
                                                    MinWidth="96"
                                                    HorizontalAlignment="Right"
                                                    Command="{Binding #Root.DataContext.StartRebindCommand}"
                                                    CommandParameter="{Binding}">
                                                <TextBlock Text="{locale:Localize Settings.HotKey.Rebind}" />
                                            </Button>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </ScrollViewer>
            <Border Grid.RowSpan="2"
                    IsVisible="{Binding IsRebinding}"
                    Background="#AA000000"
                    Focusable="True"
                    AttachedToVisualTree="HotKeyCapture_OnAttachedToVisualTree"
                    KeyDown="HotKeyCapture_OnKeyDown"
                    KeyUp="HotKeyCapture_OnKeyUp"
                    PointerPressed="HotKeyCapture_OnPointerPressed"
                    PointerReleased="HotKeyCapture_OnPointerReleased">
                <Border HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Width="420"
                        Padding="20"
                        Classes="card">
                    <StackPanel Spacing="12">
                        <TextBlock HorizontalAlignment="Center"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Text="{Binding RebindingTitle}" />
                        <TextBlock HorizontalAlignment="Center"
                                   Opacity="0.85"
                                   Text="{locale:Localize Settings.HotKey.CapturePrompt}" />
                        <Border Classes="tag"
                                Padding="10"
                                MinHeight="46">
                            <TextBlock VerticalAlignment="Center"
                                       Text="{Binding RebindingPreview}" />
                        </Border>
                        <StackPanel Orientation="Horizontal"
                                    Spacing="10"
                                    HorizontalAlignment="Center">
                            <Button MinWidth="120"
                                    Command="{Binding ConfirmRebindCommand}">
                                <TextBlock Text="{locale:Localize Settings.HotKey.SaveBinding}" />
                            </Button>
                            <Button MinWidth="100"
                                    Command="{Binding CancelRebindCommand}">
                                <TextBlock Text="{locale:Localize Settings.HotKey.CancelRebind}" />
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Border>
        </Grid>
    
</UserControl>
